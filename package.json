{
  "name": "cosim-web-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=development concurrently \"node server/server.js\" \"vite --config client/vite.config.js\"",
    "client": "vite --config client/vite.config.js",
    "server": "cross-env NODE_ENV=development node server/server.js",
    "build": "vite build --config client/vite.config.js",
    "start": "cross-env NODE_ENV=production node server/server.js"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "chart.js": "^4.5.1",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "lucide-react": "^0.562.0",
    "path": "^0.12.7",
    "react": "^19.2.3",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.3",
    "react-router-dom": "^7.11.0",
    "tailwindcss": "^4.1.18",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/react-router-dom": "^5.3.3",
    "@vitejs/plugin-react": "^5.1.2",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^17.0.0",
    "vite": "^7.3.0"
  }
}
