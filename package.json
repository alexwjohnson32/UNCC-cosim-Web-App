{
  "name": "cosim-web-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=development concurrently \"node server/server.js\" \"vite --config client/vite.config.js\"",
    "client": "vite --config client/vite.config.js",
    "server": "cross-env NODE_ENV=development node server/server.js",
    "build": "vite build --config client/vite.config.js",
    "start": "cross-env NODE_ENV=production node server/server.js"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.12",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "lucide-react": "^0.541.0",
    "path": "^0.12.7",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.8.1",
    "tailwindcss": "^4.1.12",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/react": "^19.1.11",
    "@types/react-dom": "^19.1.7",
    "@types/react-router-dom": "^5.3.3",
    "@vitejs/plugin-react": "^5.0.1",
    "concurrently": "^9.2.0",
    "cross-env": "^10.0.0",
    "eslint": "^9.33.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "vite": "^7.1.3"
  }
}
