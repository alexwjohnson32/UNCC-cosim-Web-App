{
  "name": "cosim-web-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"bun server/server.js\" \"bun run dev:build:poll\"",
    "dev:build:poll": "bun scripts/build-poll.ts",
    "build:client": "bunx @tailwindcss/cli -i ./client/src/tailwind.css -o ./client/generated.css && bun build ./client/index.html --outdir=dist/client --minify && date +%s%3N > dist/client/.build-id",
    "build:server": "bun build ./server/server.js --outdir=dist/server --minify",
    "build": "bun run build:client && bun run build:server",
    "start": "NODE_ENV=production bun dist/server/server.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "lucide-react": "^0.562.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-router-dom": "^7.12.0",
    "tailwindcss": "^4.1.18",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@tailwindcss/cli": "^4.1.18",
    "@types/bun": "^1.3.5",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/react-router-dom": "^5.3.3",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.0.0"
  }
}